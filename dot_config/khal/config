[calendars]
# Uncomment and configure your calendar:
# [[personal]]
# path = ~/.calendars/personal/
# color = lavender
# type = discover

[locale]
timeformat = %H:%M
dateformat = %Y-%m-%d
longdateformat = %Y-%m-%d
datetimeformat = %Y-%m-%d %H:%M
longdatetimeformat = %Y-%m-%d %H:%M
default_calendar = personal

[default]
default_calendar = personal
show_all_days = True
