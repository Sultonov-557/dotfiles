# Zathura — Document viewer
# Catppuccin Mocha theme
# Managed by chezmoi

set window-title-home-tilde true

# --- Appearance ---
set default-bg "#1e1e2e"
set default-fg "#cdd6f4"
set statusbar-fg "#cdd6f4"
set statusbar-bg "#1e1e2e"
set inputbar-bg "#1e1e2e"
set inputbar-fg "#cdd6f4"
set notification-bg "#1e1e2e"
set notification-fg "#cdd6f4"
set notification-error-bg "#1e1e2e"
set notification-error-fg "#f38ba8"
set notification-warning-bg "#1e1e2e"
set notification-warning-fg "#f9e2af"
set highlight-color "#45475a"
set highlight-active-color "#b4befe"
set completion-bg "#1e1e2e"
set completion-fg "#cdd6f4"
set completion-group-bg "#313244"
set completion-group-fg "#b4befe"
set completion-highlight-fg "#11111b"
set completion-highlight-bg "#b4befe"
set recolor-lightcolor "#11111b"
set recolor-darkcolor "#cdd6f4"
set index-bg "#1e1e2e"
set index-fg "#cdd6f4"
set index-active-bg "#45475a"
set index-active-fg "#b4befe"
set render-loading-bg "#1e1e2e"
set render-loading-fg "#cdd6f4"

# --- Behavior ---
set sandbox strict
set scroll-step 50
set scroll-hstep 50
set zoom-step 0.1
set pages-per-row 1
set page-padding 4
set adjust-open  best-fit
set font "JetBrainsMono Nerd Font 11"
set guioptions "c"
set statusbar-h-padding 4
set statusbar-v-padding 4

# --- Keybindings ---
map j scroll-down
map k scroll-up
map h scroll-left
map l scroll-right
map d half-page-down
map u half-page-up
map <C-d> page-down
map <C-u> page-up
map r reload
map R rotate
map i recolor
map f toggle-fullscreen
map p print
map <C-n> zoom-in
map <C-p> zoom-out
map <C-+> zoom-in
map <C--> zoom-out
map <C-0> zoom-fit
map / search-forward
map ? search-backward
map n search-next
map N search-prev
map b toggle-page-mode
map <Space> toggle-index
