[user]
	name = {{ .name }}
	email = {{ .email }}

[core]
	editor = nvim
	autocrlf = input
	whitespace = trailing-space,space-before-tab

[init]
	defaultBranch = main

[push]
	autoSetupRemote = true
	default = simple
	followTags = true

[pull]
	rebase = true

[fetch]
	prune = true
	pruneTags = true
	all = true

[rebase]
	autoStash = true
	updateRefs = true

[merge]
	conflictStyle = zdiff3

[diff]
	algorithm = histogram
	submodule = log

[status]
	submoduleSummary = true

[submodule]
	recurse = true

# --- Per-directory config includes ---
[includeIf "gitdir:~/work/"]
	path = ~/.config/git/config-work
[includeIf "gitdir:~/Projects/"]
	path = ~/.config/git/config-personal

# --- Aliases ---
[alias]
	# Log
	lg = log --graph --pretty=format:'%C(yellow)%h%C(reset) %C(cyan)%an%C(reset) %C(green)%ad%C(reset) %s%C(red)%d%C(reset)' --date=short
	lga = log --graph --all --pretty=format:'%C(yellow)%h%C(reset) %C(cyan)%an%C(reset) %C(green)%ad%C(reset) %s%C(red)%d%C(reset)' --date=short
	ll = log --oneline --graph
	lll = log --oneline --graph --all

	# Branch
	br = branch -a
	co = checkout
	cob = checkout -b
	cleanup = branch --merged | grep -v '\\*\\|master\\|main\\|develop' | xargs -r git branch -d

	# Commit
	cia = add --all && git commit
	ci = commit
	amend = commit --amend --no-edit
	reword = commit --amend
	fixup = commit --fixup
	squash = commit --squash

	# Diff
	d = diff
	dc = diff --cached
	ds = diff --stat
	dt = difftool
	w = show --shortstat

	# Status
	st = status -sb
	ss = status

	# Remote
	up = remote update --prune
	pu = push -u origin HEAD

	# Revert / reset
	undo = reset --soft HEAD~1
	unstage = restore --staged
	discard = restore
	discard-all = restore .
	wipe = reset --hard HEAD && git clean -fd

	# Worktree
	wt = worktree
	wta = worktree add
	wtl = worktree list
	wtr = worktree remove

	# Useful
	who = shortlog -sn
	contributors = shortlog -sn --no-merges
	sc = shortlog -sn
	bl = blame -b -w
	tags = tag --sort=-version:refname
	recent = for-each-ref --sort=-committerdate refs/heads/ --format='%(HEAD) %(color:yellow)%(refname:short)%(color:reset) - %(color:green)%(committerdate:relative)%(color:reset) - %(color:cyan)%(authorname)%(color:reset) - %(contents:subject)'
	rank = shortlog -sn --no-merges

	# Search
	grep = grep --break --heading --line-number
	search = log -S
	find = log --all --oneline --grep

	# File
	cp = cherry-pick
	ignored = ls-files --others -i --exclude-standard

{{ if ne .machine_type "desktop" -}}
# --- Machine-specific: server/laptop get GPG signing ---
[commit]
	gpgSign = true
[tag]
	gpgSign = true
[gpg]
	program = gpg
{{ end -}}

[credential "https://github.com"]
       helper =
       helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
       helper =
       helper = !/usr/bin/gh auth git-credential
