# ~/.xprofile — legacy X11 login shell env vars
# Loaded by GDM/SDDM and other display managers for X11 sessions
# On Wayland+Hyprland, these are also sourced by the login manager
# Managed by chezmoi

# PATH additions
[[ -d "$HOME/.local/bin" ]] && export PATH="$HOME/.local/bin:$PATH"
[[ -d "$HOME/.cargo/bin" ]] && export PATH="$HOME/.cargo/bin:$PATH"
[[ -d "$HOME/.npm-global/bin" ]] && export PATH="$HOME/.npm-global/bin:$PATH"

# Default programs
export EDITOR=nvim
export VISUAL=nvim
export BROWSER=zen-browser
export TERMINAL=ghostty

# Wayland
export XDG_SESSION_TYPE=wayland
export XDG_CURRENT_DESKTOP=Hyprland
export GDK_BACKEND=wayland,x11
export QT_QPA_PLATFORM=wayland;xcb
export SDL_VIDEODRIVER=wayland
export MOZ_ENABLE_WAYLAND=1
export _JAVA_AWT_WM_NONREPARENTING=1
export NIXOS_OZONE_WL=1

# Theme
export GTK_THEME=Catppuccin-Mocha-Standard-Lavender-Dark
export QT_STYLE_OVERRIDE=kvantum
export BAT_THEME=Catppuccin\ Mocha

# Cursor
export XCURSOR_THEME=Bibata-Modern-Classic
export XCURSOR_SIZE=24
